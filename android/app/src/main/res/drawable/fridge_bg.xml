<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fridge body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFE8E0D0" />
            <corners android:radius="16dp" />
            <stroke android:width="3dp" android:color="#FF8D6E63" />
        </shape>
    </item>
    <!-- "Paper note" inner -->
    <item android:left="8dp" android:top="40dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFDE7" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list>
